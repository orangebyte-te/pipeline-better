# GitLab CI/CD variables template for insgeek-business-test -> pipeline-better backend pipeline
# Scope: current repositories only
# Note: yaml-config runtime env is intentionally NOT included here

# ================================
# Runner scheduling
# ================================
# Current templates inject RUNNER_TAG directly in workflow rules.
# The validated backend/frontend release path currently uses:
#   RUNNER_TAG=dev-runner-k8s-ali
# So no RUNNER_TAG_* CI variables are required unless you later refactor
# the workflow to read runner tags from GitLab CI variables again.

# ================================
# Required: notifications
# ================================
# notify_success / notify_failure consume this.
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_DINGTALK_ACCESS_TOKEN

# ================================
# Required: deployment config repo access
# ================================
# update_deploy_repo clones yaml-config and updates deploy metadata there.
YAML_CONFIG_REPO_HTTP=gitlab.insgeek.cn/devops/yaml-config.git
YAML_CONFIG_REPO_TOKEN=YOUR_YAML_CONFIG_TOKEN
YAML_CONFIG_REPO_BRANCH=release

# ================================
# Recommended: SonarQube
# ================================
# develop branch uses sonar_scan / notify_quality_gate.
SONAR_HOST_URL=http://sonarqube.insgeek.cn
SONAR_TOKEN=YOUR_SONAR_TOKEN

# ================================
# Optional: image registry
# ================================
# If omitted, templates fall back to harbor.insgeek.cn.
REGISTRY=harbor.insgeek.cn
REGISTRY_USER=YOUR_HARBOR_USERNAME
REGISTRY_PASSWORD=YOUR_HARBOR_PASSWORD

# ================================
# Optional: template repo location
# ================================
# Keep include ref and TEMPLATE_REF aligned. The validated business repo uses main.
TEMPLATE_PROJECT_PATH_ENCODED=devops%2Fpipeline-better
TEMPLATE_REF=main

# ================================
# Informational only
# ================================
DEFAULT_SERVER_PORT=8080
DEFAULT_DOCKERFILE_BACKEND=Dockerfile.backend-jdk8-agent
