# GitLab CI/CD Variables 示例
# 这份示例按当前已经跑通的 example-business-test -> pipeline-better 接入整理。
# 当前 workflow 里直接注入 RUNNER_TAG=generic-runner-k8s，因此不需要额外配置 RUNNER_TAG_*。

DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=***

# develop 分支需要 Sonar；如果只验证 release 链路，可后补。
SONAR_HOST_URL=http://sonarqube.example.internal
SONAR_TOKEN=***

YAML_CONFIG_REPO_HTTP=gitlab.example.internal/ci-templates/deployment-config.git
YAML_CONFIG_REPO_BRANCH=release
YAML_CONFIG_REPO_TOKEN=***

REGISTRY=harbor.example.internal
REGISTRY_USER=***
REGISTRY_PASSWORD=***

# 可选：仅在模板仓库路径或分支与默认值不一致时覆盖
TEMPLATE_PROJECT_PATH_ENCODED=ci-templates%2Fpipeline-better
TEMPLATE_REF=main

# 可选：说明型变量
DEFAULT_SERVER_PORT=8080
DEFAULT_DOCKERFILE_BACKEND=Dockerfile.backend-jdk8-agent
DEFAULT_DOCKERFILE_FRONTEND=Dockerfile.frontend-nginx
